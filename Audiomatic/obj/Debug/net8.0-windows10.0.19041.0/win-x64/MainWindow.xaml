<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Audiomatic.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Audiomatic">

    <Grid x:ConnectionId='2' x:Name="RootGrid"                           
                                            >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Custom title bar (drag area) -->
        <Grid x:ConnectionId='3' x:Name="CustomTitleBar" Grid.Row="0" Height="32" Background="Transparent"
              Padding="12,0"
                                                      
                                                  
                                                        >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Collapse/Expand toggle -->
            <Button x:ConnectionId='38' x:Name="CollapseButton" Grid.Column="1"
                    Background="Transparent" BorderThickness="0"
                    Padding="6,4"                             
                    ToolTipService.ToolTip="Compact (Ctrl+L)">
                <FontIcon x:ConnectionId='42' x:Name="CollapseIcon" Glyph="&#xE73F;" FontSize="11"/>
            </Button>

            <Button x:ConnectionId='39' x:Name="PinButton" Grid.Column="2"
                    Background="Transparent" BorderThickness="0"
                    Padding="6,4"                  
                    ToolTipService.ToolTip="Pin on top">
                <FontIcon x:ConnectionId='41' x:Name="PinIcon" Glyph="&#xE840;" FontSize="11"/>
            </Button>

            <Button x:ConnectionId='40' Grid.Column="3" Background="Transparent" BorderThickness="0"
                    Padding="6,4"                    >
                <FontIcon Glyph="&#xE711;" FontSize="11"/>
            </Button>
        </Grid>

        <!-- Row 1: Now Playing card (also drag area) -->
        <Grid x:ConnectionId='4' x:Name="NowPlayingCard" Grid.Row="1" Padding="14,4,14,8"
              Background="Transparent"
                                                      
                                                  
                                                        >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Album art -->
            <Grid Grid.Column="0" Width="56" Height="56" CornerRadius="6"
                  Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                <Image x:ConnectionId='36' x:Name="AlbumArtImage" Stretch="UniformToFill"
                       Width="56" Height="56"/>
                <FontIcon x:ConnectionId='37' x:Name="AlbumArtPlaceholder" Glyph="&#xE8D6;" FontSize="24"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
            </Grid>

            <!-- Track info -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1" Margin="12,0,0,0">
                <TextBlock x:ConnectionId='33' x:Name="TrackTitle" Text="No track"
                           FontWeight="SemiBold" FontSize="14"
                           TextTrimming="CharacterEllipsis" MaxLines="1"/>
                <TextBlock x:ConnectionId='34' x:Name="TrackArtist" Text=""
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextTrimming="CharacterEllipsis" MaxLines="1"/>
                <TextBlock x:ConnectionId='35' x:Name="TrackAlbum" Text=""
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           TextTrimming="CharacterEllipsis" MaxLines="1"
                           FontSize="11"/>
            </StackPanel>
        </Grid>

        <!-- Row 2: Timeline (progress bar + times) -->
        <Grid Grid.Row="2" Padding="14,0,14,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Slider x:ConnectionId='30' x:Name="TimelineSlider" Grid.Row="0"
                    Minimum="0" Maximum="100" Value="0"
                    Height="24"
                                                              />

            <Grid Grid.Row="1" Margin="0,-4,0,0">
                <TextBlock x:ConnectionId='31' x:Name="PositionText" Text="0:00"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           FontSize="11"
                           HorizontalAlignment="Left"/>
                <TextBlock x:ConnectionId='32' x:Name="DurationText" Text="0:00"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           FontSize="11"
                           HorizontalAlignment="Right"/>
            </Grid>
        </Grid>

        <!-- Row 3: Playback controls -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="4"
                    HorizontalAlignment="Center" Padding="14,4,14,4">
            <Button x:ConnectionId='22' x:Name="ShuffleButton" Background="Transparent" BorderThickness="0"
                    Padding="8,6"                      
                    ToolTipService.ToolTip="Shuffle" VerticalAlignment="Center">
                <FontIcon x:ConnectionId='29' x:Name="ShuffleIcon" Glyph="&#xE8B1;" FontSize="14"/>
            </Button>
            <Button x:ConnectionId='23' Background="Transparent" BorderThickness="0"
                    Padding="8,6"                   
                    ToolTipService.ToolTip="Previous" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE892;" FontSize="18"/>
            </Button>

            <!-- Play/Pause: large round filled button -->
            <Button x:ConnectionId='24' x:Name="PlayPauseButton"
                    Width="48" Height="48" CornerRadius="24"
                    Padding="0" Margin="4,0"
                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                    Foreground="White"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                                           >
                <FontIcon x:ConnectionId='28' x:Name="PlayPauseIcon" Glyph="&#xE768;" FontSize="22"
                          Foreground="White"/>
            </Button>

            <Button x:ConnectionId='25' Background="Transparent" BorderThickness="0"
                    Padding="8,6"                   
                    ToolTipService.ToolTip="Next" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE893;" FontSize="18"/>
            </Button>
            <Button x:ConnectionId='26' x:Name="RepeatButton" Background="Transparent" BorderThickness="0"
                    Padding="8,6"                     
                    ToolTipService.ToolTip="Repeat" VerticalAlignment="Center">
                <FontIcon x:ConnectionId='27' x:Name="RepeatIcon" Glyph="&#xE8EE;" FontSize="14"/>
            </Button>
        </StackPanel>

        <!-- Row 3b: Volume bar (separate row) -->
        <Grid x:ConnectionId='5' x:Name="VolumeRow" Grid.Row="4" Padding="14,0,14,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button x:ConnectionId='19' Grid.Column="0" Background="Transparent" BorderThickness="0"
                    Padding="4,4"                    VerticalAlignment="Center">
                <FontIcon x:ConnectionId='21' x:Name="VolumeIcon" Glyph="&#xE995;" FontSize="13"/>
            </Button>
            <Slider x:ConnectionId='20' x:Name="VolumeSlider" Grid.Column="1"
                    Minimum="0" Maximum="100" Value="100"
                    Height="24"
                                                 
                    VerticalAlignment="Center"/>
        </Grid>

        <!-- Row 5: Search + Sort -->
        <Grid x:ConnectionId='6' x:Name="SearchSortRow" Grid.Row="5" Padding="14,0,14,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:ConnectionId='12' x:Name="SearchBox" Grid.Column="0"
                     PlaceholderText="Search"
                     FontSize="13"
                     Padding="8,6"
                     CornerRadius="6"
                                                        >
                <TextBox.BorderBrush>
                    <SolidColorBrush Color="{ThemeResource ControlStrokeColorDefault}"/>
                </TextBox.BorderBrush>
            </TextBox>

            <DropDownButton x:ConnectionId='13' x:Name="SortButton" Grid.Column="1" Margin="6,0,0,0"
                            Padding="8,6">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE8CB;" FontSize="12"/>
                </StackPanel>
                <DropDownButton.Flyout>
                    <MenuFlyout>
                        <ToggleMenuFlyoutItem x:ConnectionId='14' x:Name="SortTitle" Text="Title"                    Tag="title" IsChecked="True"/>
                        <ToggleMenuFlyoutItem x:ConnectionId='15' x:Name="SortArtist" Text="Artist"                    Tag="artist"/>
                        <ToggleMenuFlyoutItem x:ConnectionId='16' x:Name="SortAlbum" Text="Album"                    Tag="album"/>
                        <ToggleMenuFlyoutItem x:ConnectionId='17' x:Name="SortDuration" Text="Duration"                    Tag="duration"/>
                        <MenuFlyoutSeparator/>
                        <ToggleMenuFlyoutItem x:ConnectionId='18' x:Name="SortAscending" Text="Ascending" IsChecked="True"                            />
                    </MenuFlyout>
                </DropDownButton.Flyout>
            </DropDownButton>
        </Grid>

        <!-- Row 6: Track list -->
        <ListView x:ConnectionId='7' x:Name="TrackListView" Grid.Row="6"
                  Padding="6,0"
                  SelectionMode="Single"
                  IsItemClickEnabled="True"
                                                 >
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="8,4"/>
                    <Setter Property="MinHeight" Value="48"/>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <!-- Row 7: Bottom bar -->
        <Grid x:ConnectionId='8' x:Name="BottomBar" Grid.Row="7" Padding="10,6,10,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:ConnectionId='9' Grid.Column="0" Background="Transparent" BorderThickness="0"
                    Padding="6,3"                           >
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE838;" FontSize="12"/>
                    <TextBlock Text="Choose Folder"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               FontSize="11"/>
                </StackPanel>
            </Button>

            <TextBlock x:ConnectionId='10' x:Name="TrackCountText" Grid.Column="2"
                       Text="0 tracks"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       VerticalAlignment="Center"
                       FontSize="11"
                       Margin="0,0,6,0"/>

            <Button x:ConnectionId='11' Grid.Column="3" Background="Transparent" BorderThickness="0"
                    Padding="6,3"                       
                    ToolTipService.ToolTip="Settings">
                <FontIcon Glyph="&#xE713;" FontSize="13"/>
            </Button>
        </Grid>
    </Grid>
</Window>

