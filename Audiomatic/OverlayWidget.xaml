<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Audiomatic.OverlayWidget"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Audiomatic">

    <Grid x:Name="RootGrid"
          PointerPressed="Root_PointerPressed"
          PointerMoved="Root_PointerMoved"
          PointerReleased="Root_PointerReleased"
          Background="Transparent"
          CornerRadius="12">

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Main content row -->
        <Grid Grid.Row="0" Padding="10,10,6,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Album art -->
            <Grid Grid.Column="0" Width="48" Height="48" CornerRadius="6"
                  Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                <Image x:Name="OverlayAlbumArt" Stretch="UniformToFill"
                       Width="48" Height="48"/>
                <FontIcon x:Name="OverlayArtPlaceholder" Glyph="&#xE8D6;" FontSize="20"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
            </Grid>

            <!-- Track info -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1" Margin="10,0,4,0">
                <TextBlock x:Name="OverlayTitle" Text="No track"
                           FontWeight="SemiBold" FontSize="13"
                           TextTrimming="CharacterEllipsis" MaxLines="1"/>
                <TextBlock x:Name="OverlayArtist" Text=""
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextTrimming="CharacterEllipsis" MaxLines="1"
                           FontSize="11"/>
            </StackPanel>

            <!-- Previous -->
            <Button Grid.Column="2" Background="Transparent" BorderThickness="0"
                    Padding="6,6" Click="Prev_Click" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE892;" FontSize="14"/>
            </Button>

            <!-- Play/Pause -->
            <Button x:Name="OverlayPlayPauseBtn" Grid.Column="3"
                    Width="36" Height="36" CornerRadius="18"
                    Padding="0" Margin="2,0"
                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                    Foreground="White"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Click="PlayPause_Click">
                <FontIcon x:Name="OverlayPlayPauseIcon" Glyph="&#xE768;" FontSize="16"
                          Foreground="White"/>
            </Button>

            <!-- Next -->
            <Button Grid.Column="4" Background="Transparent" BorderThickness="0"
                    Padding="6,6" Click="Next_Click" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE893;" FontSize="14"/>
            </Button>

            <!-- Close -->
            <Button Grid.Column="5" Background="Transparent" BorderThickness="0"
                    Padding="4,4" Click="Close_Click" VerticalAlignment="Top"
                    Margin="0,-2,-2,0">
                <FontIcon Glyph="&#xE711;" FontSize="9"
                          Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
            </Button>
        </Grid>

        <!-- Progress bar at bottom -->
        <ProgressBar x:Name="OverlayProgress" Grid.Row="1"
                     Minimum="0" Maximum="1000" Value="0"
                     Height="3" Margin="0,0,0,0"/>
    </Grid>
</Window>
