<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Audiomatic.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Settings">

    <Grid KeyDown="RootGrid_KeyDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom title bar -->
        <Grid x:Name="CustomTitleBar" Grid.Row="0" Padding="8,6" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="TitleBarText" Grid.Column="0"
                       Text="Settings"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            <Button Grid.Column="1" Background="Transparent" BorderThickness="0"
                    Padding="8,4" Click="Close_Click">
                <FontIcon Glyph="&#xE711;" FontSize="12"/>
            </Button>
        </Grid>

        <!-- Tab selector -->
        <SelectorBar x:Name="SettingsSelector" Grid.Row="1" Margin="20,4,20,0"
                     SelectionChanged="SettingsSelector_SelectionChanged">
            <SelectorBarItem x:Name="SelectorFolders" Text="Folders" IsSelected="True"/>
            <SelectorBarItem x:Name="SelectorAppearance" Text="Appearance"/>
        </SelectorBar>

        <!-- Folders page -->
        <ScrollViewer x:Name="FoldersPage" Grid.Row="2" Padding="20,10,20,20">
            <StackPanel Spacing="16">
                <TextBlock Text="Music Folders"
                           Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <TextBlock Text="Add folders containing your music files. They will be scanned for audio tracks."
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"/>

                <StackPanel x:Name="FoldersList" Spacing="4"/>

                <Button x:Name="AddFolderButton" Click="AddFolder_Click"
                        HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE710;" FontSize="12"/>
                        <TextBlock Text="Add Folder"/>
                    </StackPanel>
                </Button>

                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                    <Button x:Name="ScanButton" Click="Scan_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE72C;" FontSize="12"/>
                            <TextBlock Text="Scan Now"/>
                        </StackPanel>
                    </Button>
                    <TextBlock x:Name="ScanStatus"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <ProgressBar x:Name="ScanProgress" Visibility="Collapsed"
                             Minimum="0" Maximum="100" Height="3"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Appearance page -->
        <ScrollViewer x:Name="AppearancePage" Grid.Row="2" Padding="20,10,20,20"
                      Visibility="Collapsed">
            <StackPanel Spacing="24">
                <StackPanel Spacing="8">
                    <TextBlock Text="Backdrop Effect"
                               Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBlock Text="Choose the visual effect applied to the window background."
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"/>
                    <RadioButtons x:Name="BackdropRadio" SelectionChanged="BackdropRadio_SelectionChanged">
                        <RadioButton x:Name="RadioAcrylic" Content="Acrylic" Tag="acrylic"/>
                        <RadioButton x:Name="RadioMica" Content="Mica" Tag="mica"/>
                        <RadioButton x:Name="RadioMicaAlt" Content="Mica Alt" Tag="mica_alt"/>
                        <RadioButton x:Name="RadioNone" Content="None" Tag="none"/>
                    </RadioButtons>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
